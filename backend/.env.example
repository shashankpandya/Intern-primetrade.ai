DATABASE_URL="postgresql://postgres:postgres@localhost:5432/primetrade?schema=public"
PORT=5000
NODE_ENV=development
JWT_ACCESS_SECRET="replace-with-strong-access-secret"
JWT_REFRESH_SECRET="replace-with-strong-refresh-secret"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"
# For production, add multiple origins separated by commas:
# CORS_ORIGIN="http://localhost:5173,https://your-frontend-domain.vercel.app"
CORS_ORIGIN="http://localhost:5173"
