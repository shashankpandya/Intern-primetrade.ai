# For local development, the frontend automatically uses http://localhost:5000/api/v1.
# In production, set VITE_API_BASE_URL to your backend URL if you want direct client->API calls.
# If VITE_API_BASE_URL is not set, frontend uses /api/v1 and depends on vercel.json rewrites.
# Example:
# VITE_API_BASE_URL="https://intern-primetrade-api.onrender.com/api/v1"
